rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }
    function isAdmin() { return isAuth() && request.auth.token.role == 'admin'; }

    match /bookings/{date} {
      allow read, write: if isAuth();
    }

    match /weeklyplan/{week} {
      allow read, write: if isAuth();
    }

    match /teyit/{date} {
      allow read, write: if isAuth();
    }

    match /notes/{week} {
      allow read, write: if isAuth();
    }

    // Personel listesi: oturum açmış herkes okuyabilir, sadece admin yazabilir
    match /config/persons {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Admin PIN hash artık kullanılmıyor — Firebase Auth'a geçildi
    match /config/auth {
      allow read, write: if false;
    }

    // SMTP ayarları: şifre içerdiği için client'tan erişilemez
    match /config/smtp {
      allow read, write: if false;
    }

    match /analytics_sessions/{doc} {
      allow read: if isAdmin();
      allow write: if isAuth();
    }

    match /analytics_activity/{doc} {
      allow read: if isAdmin();
      allow write: if isAuth();
    }
  }
}
